{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "competitive/block5_output.schema.json",
  "title": "Competitive Block5 Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["block", "вывод_по_опорному", "tech_by_place"],
  "properties": {
    "block": { "const": "block5_tech" },
    "вывод_по_опорному": { "type": "string" },
    "tech_by_place": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^.+$": { "$ref": "#/$defs/placeTech" }
      }
    }
  },
  "$defs": {
    "errorEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "error", "вывод"],
      "properties": {
        "url": { "type": ["string", "null"] },
        "error": { "type": "string", "minLength": 1 },
        "вывод": { "type": "string" },
        "is_reference_place": { "const": true }
      }
    },
    "okEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "status_code",
        "load_time_sec",
        "mobile_load_time_sec",
        "page_size_kb",
        "title",
        "meta_description",
        "https",
        "has_viewport",
        "error",
        "вывод"
      ],
      "properties": {
        "url": { "type": "string", "minLength": 1 },
        "status_code": { "type": "integer", "minimum": 100, "maximum": 599 },
        "load_time_sec": { "type": "number", "minimum": 0 },
        "mobile_load_time_sec": { "type": "number", "minimum": 0 },
        "page_size_kb": { "type": "number", "minimum": 0 },
        "title": { "type": ["string", "null"] },
        "meta_description": { "type": ["string", "null"] },
        "https": { "type": "boolean" },
        "has_viewport": { "type": "boolean" },
        "error": { "type": "null" },
        "вывод": { "type": "string" },
        "is_reference_place": { "const": true }
      }
    },
    "placeTech": {
      "oneOf": [
        { "$ref": "#/$defs/errorEntry" },
        { "$ref": "#/$defs/okEntry" }
      ]
    }
  }
}
